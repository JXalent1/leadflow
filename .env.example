# LeadFlow environment variables. Copy to .env.local and fill in real values.
# In Vercel these are injected by the Neon integration / project settings.

# --- Database (Neon via Vercel Marketplace integration) ---
# Pooled connection string used by the app and scripts (@neondatabase/serverless).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# Direct (non-pooled) connection — provided by Neon; used for migrations if ever needed.
DATABASE_URL_UNPOOLED=postgres://user:password@host/dbname?sslmode=require
# The POSTGRES_* vars below are auto-provided by the Vercel Neon integration. Kept for parity.
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:password@host/dbname?sslmode=require
POSTGRES_PRISMA_URL=postgres://user:password@host/dbname?sslmode=require
PGHOST=host
PGUSER=user
PGPASSWORD=password
PGDATABASE=dbname

# --- Auth (v2 Module V5 — real per-user login; replaces the shared ADMIN_PASSWORD gate) ---
# REQUIRED. Server-side secret that signs the httpOnly session cookie (HMAC-SHA256). Must be a long
# random string (≥16 chars; use 32+). If unset, login fails closed. Rotating it logs everyone out.
SESSION_SECRET=change-me-to-a-long-random-string
# Used ONLY by `npm run seed:users` to create the initial accounts (operator + Talan client). Not
# read at runtime. Passwords are hashed with scrypt before storage — never persisted in plaintext.
OPERATOR_EMAIL=you@dr.x
OPERATOR_PASSWORD=set-a-strong-password
CLIENT1_EMAIL=talan@example.com
CLIENT1_PASSWORD=set-a-strong-password
# ADMIN_PASSWORD is DEPRECATED (the single shared-password gate was removed in V5). Safe to delete.

# --- Twilio (Session 3 — SMS send + inbound webhook) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Twilio account SID
TWILIO_AUTH_TOKEN=your-twilio-auth-token                # Twilio auth token
TWILIO_FROM_NUMBER=+18505551234                         # Aged 10DLC sending number
TWILIO_MESSAGING_SERVICE_SID=                           # optional — preferred for 10DLC; overrides FROM_NUMBER if set
TWILIO_WEBHOOK_URL=                                     # optional (Session 4) — exact public webhook URL for signature validation; else reconstructed from x-forwarded-* headers
TWILIO_ADVANCED_OPT_OUT=                                # optional (Session 4) — set "true" ONLY if a Messaging Service with Advanced Opt-Out is enabled (Twilio sends the STOP confirmation; we won't)
SMOKE_TO_NUMBER=+16195551234                            # your own phone — recipient of the smoke-test text
# v2 NOTE: per-client send config now lives in the `clients` DB table (biz_name, message_template,
# from_number/messaging_service_sid, send_window_*, send_timezone, send_rate_per_hour,
# optout_confirmation, forward_phone). The env vars below are now only FALLBACK defaults used by the
# smoke scripts / any pre-v2 path — live routes read them from the client record. Account-level
# secrets (TWILIO_ACCOUNT_SID/AUTH_TOKEN, TRACERFY_API_KEY, DATABASE_URL, SESSION_SECRET) stay in env.
BIZ_NAME=Talan Window Cleaning                          # fallback [BIZ] (per-client: clients.biz_name)
SEND_RATE_PER_HOUR=60                                   # fallback sends/hour (per-client: clients.send_rate_per_hour)
SEND_WINDOW_START_HOUR=10                               # fallback inclusive local start hour
SEND_WINDOW_END_HOUR=19                                 # fallback exclusive local end hour
SEND_TIMEZONE=America/New_York                          # fallback campaign timezone (Talan is Eastern; per-client: clients.send_timezone)
AB_VARIANTS=A,B,C                                       # active A/B cells (e.g. "A,B" for 2 cells)

# --- Conversational AI responder (Build: ai-responder) ---
# Replicates Lance's GHL SMS AI: reads intent, replies in a human voice, qualifies, and forwards
# hot leads. STOP / the per-client opt-out keyword / suppression are ALWAYS handled deterministically
# BEFORE the AI — the responder never runs on, or texts, an opted-out/suppressed contact. Ships OFF:
# even with a key set, AI_RESPONDER_ENABLED must be "true" AND the client must have ai_enabled=true.
ANTHROPIC_API_KEY=                                      # Anthropic API key (Claude) — required for the AI responder; absent ⇒ responder falls back to the keyword path
AI_RESPONDER_ENABLED=                                   # global kill switch — set "true" to allow the responder for ai_enabled clients (default off)
AI_RESPONDER_MODEL=                                     # optional — Claude model id (default claude-opus-4-8)
AI_RESPONDER_MAX_TURNS=                                 # optional — max AI replies per conversation (default 5)

# --- Tracerfy (Session 2 — skip trace + DNC/litigator scrub) ---
TRACERFY_API_KEY=your-tracerfy-bearer-token             # Tracerfy REST API bearer token

# --- Lead forwarding (Session 4) ---
# SMS only — no email/Resend (dropped 2026-06-22). The lead row (dashboard) is the durable record;
# this number gets a one-line ping per interested reply. Your own phone works as a stand-in for testing.
TALAN_FORWARD_PHONE=+18505550000                        # Client's cell — forwarded leads via SMS
